<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.studyforge.interaction.mapper.CommentMapper">
    <resultMap id="CommentResultMap" type="com.studyforge.interaction.entity.Comment">
        <id column="comment_id" property="commentId"/>
        <result column="post_id" property="postId"/>
        <result column="user_id" property="userId"/>
        <result column="language_code" property="languageCode"/>
        <result column="content" property="content"/>
        <result column="status" property="status"/>
        <result column="created_time" property="createdTime"/>
    </resultMap>

    <select id="selectById" resultMap="CommentResultMap">
        SELECT
            comment_id,
            post_id,
            user_id,
            language_code,
            content,
            status,
            created_time
        FROM comments
        WHERE comment_id = #{commentId}
    </select>

    <select id="selectVisibleByPostId" resultMap="CommentResultMap">
        SELECT
            comment_id,
            post_id,
            user_id,
            language_code,
            content,
            status,
            created_time
        FROM comments
        WHERE post_id = #{postId}
          AND status = 'VISIBLE'
        ORDER BY created_time ASC
    </select>

    <insert id="insert" parameterType="com.studyforge.interaction.entity.Comment" useGeneratedKeys="true" keyProperty="commentId">
        INSERT INTO comments (
            post_id,
            user_id,
            language_code,
            content,
            status
        )
        VALUES (
            #{postId},
            #{userId},
            #{languageCode},
            #{content},
            #{status}
        )
    </insert>
</mapper>
